<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Winix" Height="720" Width="980"
        MinHeight="600" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e" Foreground="#f0f0f0">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#1e1e1e"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#252526"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3e3e42"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007acc"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#005f9e"/>
        <SolidColorBrush x:Key="FgBrush" Color="#f0f0f0"/>
        <SolidColorBrush x:Key="MutedFgBrush" Color="#a0a0a0"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10,6,10,10"/>
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Height" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Project Winix" FontSize="26" FontWeight="Bold" Foreground="{StaticResource FgBrush}"/>
            <TextBlock Text="Native Unix-like CLI environment for Windows" FontSize="13" Foreground="{StaticResource MutedFgBrush}"/>
        </StackPanel>

        <!-- Options -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 1: Installation tiers -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <GroupBox Header="Installation Tiers">
                        <StackPanel>
                            <CheckBox x:Name="InstallCoreCheckBox" Content="Install Core" IsChecked="True"
                                      ToolTip="MSYS2/MinGW64, Rust, Brush, JetBrains Mono font, dotfiles, Windows Terminal profile, PATH"/>
                            <CheckBox x:Name="InstallAdvancedCheckBox" Content="Install Advanced Arsenal"
                                      ToolTip="All advanced CLI tools (bat, eza, fd, ripgrep, zellij)"/>
                            <CheckBox x:Name="InstallAllCheckBox" Content="Install Everything"
                                      ToolTip="Core + all advanced tools"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Execution Options">
                        <StackPanel>
                            <CheckBox x:Name="DryRunCheckBox" Content="Dry run"
                                      Foreground="#87ceeb"
                                      ToolTip="Log planned actions without making any system changes"/>
                            <CheckBox x:Name="WaitCheckBox" Content="Wait for key press on exit"
                                      ToolTip="Keep the window open after installation completes"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- Column 2: Advanced tools -->
                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <GroupBox Header="Advanced Tools">
                        <StackPanel>
                            <CheckBox x:Name="InstallBatCheckBox" Content="Bat (cat replacement)"/>
                            <CheckBox x:Name="InstallEzaCheckBox" Content="Eza (ls replacement)"/>
                            <CheckBox x:Name="InstallFdCheckBox" Content="fd (find replacement)"/>
                            <CheckBox x:Name="InstallRipgrepCheckBox" Content="Ripgrep (grep replacement)"/>
                            <CheckBox x:Name="InstallZellijCheckBox" Content="Zellij terminal multiplexer"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- Column 3: Options & Maintenance -->
                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <GroupBox Header="Advanced Options">
                        <StackPanel>
                            <CheckBox x:Name="BuildFromSourceCheckBox" Content="Build tools from source"
                                      ToolTip="Use cargo install instead of downloading pre-built binaries"/>
                            <CheckBox x:Name="SkipRestorePointCheckBox" Content="Skip System Restore Point"
                                      Foreground="#ff6b6b"
                                      ToolTip="DANGEROUS: skip the mandatory pre-install snapshot"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Maintenance">
                        <StackPanel>
                            <CheckBox x:Name="UninstallCheckBox" Content="Uninstall / teardown"
                                      Foreground="#ff6b6b"
                                      ToolTip="Remove the Winix profile, dotfiles, PATH entries, and optionally MSYS2"/>
                            <CheckBox x:Name="RollbackOSCheckBox" Content="Open System Restore"
                                      ToolTip="Launch Windows System Restore to revert OS state"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Consent + Log -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <CheckBox x:Name="ConsentCheckBox" Grid.Row="0" Content="I understand existing configs will be backed up and may be overwritten."
                      Foreground="#ffd700" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="LogTextBox" Grid.Row="1" Text="Ready..."/>
        </Grid>

        <!-- Progress + Buttons -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar x:Name="InstallProgressBar" Grid.Row="0" Value="0" Minimum="0" Maximum="100" Margin="0,0,0,12"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="InstallButton" Content="Install" Width="120" Margin="0,0,10,0"/>
                <Button x:Name="CancelButton" Content="Cancel" Width="120" Margin="0,0,10,0" Background="#3e3e42" BorderBrush="#3e3e42"/>
                <Button x:Name="UninstallButton" Content="Uninstall" Width="120" Background="#c75450" BorderBrush="#c75450"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
