<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Winix" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Project Winix" Foreground="White"
                   FontSize="24" FontWeight="Bold" Margin="20"/>

        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="WPF dashboard placeholder. Consent gate, tier checkboxes, progress bars, and log console will be wired in Phase 6."
                       Foreground="#cccccc" TextWrapping="Wrap" Margin="0,0,0,20"/>

            <CheckBox x:Name="ConsentCheckBox" Content="I understand existing configs will be backed up and overwritten."
                      Foreground="White" Margin="0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,20">
                <Button x:Name="InstallButton" Content="Install" Width="120" Margin="0,0,10,0"/>
                <Button x:Name="UninstallButton" Content="Uninstall" Width="120" Margin="0,0,10,0"/>
                <Button x:Name="CancelButton" Content="Cancel" Width="120"/>
            </StackPanel>

            <TextBox x:Name="LogTextBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     Background="#252526" Foreground="#d4d4d4"
                     FontFamily="Consolas" Height="200" Margin="0,20,0,0"/>
        </StackPanel>

        <StatusBar Grid.Row="2" Background="#333337">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="White"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
